# ==================== Deploy Mode ====================
# Built-in PostgreSQL (default): COMPOSE_PROFILES=postgres
# External PostgreSQL: set COMPOSE_PROFILES empty
COMPOSE_PROFILES=postgres

# ==================== Database Configuration ====================
# For external PostgreSQL, set to your own connection URL:
SPRING_DATASOURCE_URL=jdbc:postgresql://your_db_host:5432/rsswithai

# These credentials are used by Spring Boot.
# In built-in postgres mode, they are also used to initialize the postgres container.
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Optional, only used in built-in postgres mode
POSTGRES_DB=rsswithai
